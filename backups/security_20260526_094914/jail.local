[DEFAULT]
bantime  = 3600
findtime = 600
maxretry = 5

[apache-auth]
enabled  = true
port     = 87
filter   = apache-auth
logpath  = /var/log/apache2/dolibarr-error.log

[apache-dolibarr-login]
enabled  = true
port     = 87
filter   = apache-dolibarr-login
logpath  = /var/log/apache2/dolibarr-error.log
maxretry = 5
bantime  = 3600
